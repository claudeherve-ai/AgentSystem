<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Removed IsAspireHost to bypass workload requirement -->
  </PropertyGroup>
  <ItemGroup>
    <!-- Use standard Hosting packages without the Sdk-level workload requirement -->
    <PackageReference Include="Aspire.Hosting" Version="8.2.2" />
    <PackageReference Include="Aspire.Hosting.Python" Version="8.2.2" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\AgentSystem.ServiceDefaults\AgentSystem.ServiceDefaults.csproj" />
  </ItemGroup>
</Project>
