# ============================================================
# AgentSystem Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Provider (Azure OpenAI) ---
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- LLM Provider (OpenAI direct — alternative) ---
# OPENAI_API_KEY=<your-openai-key>

# --- LLM Provider (Anthropic — optional, not yet wired) ---
# Anthropic routing is stubbed for now. Leave commented until support lands;
# the app runs fine on Azure OpenAI or OpenAI alone.
# ANTHROPIC_API_KEY=<your-anthropic-key>

# --- Microsoft Graph (Email + Calendar) ---
GRAPH_CLIENT_ID=<your-app-registration-client-id>
GRAPH_CLIENT_SECRET=<your-app-registration-client-secret>
GRAPH_TENANT_ID=consumers

# --- Twitter/X ---
TWITTER_API_KEY=<your-twitter-api-key>
TWITTER_API_SECRET=<your-twitter-api-secret>
TWITTER_ACCESS_TOKEN=<your-twitter-access-token>
TWITTER_ACCESS_SECRET=<your-twitter-access-token-secret>
TWITTER_BEARER_TOKEN=<your-twitter-bearer-token>

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=<your-linkedin-oauth-access-token>

# --- OpenClaw (Telegram/WhatsApp gateway) ---
OPENCLAW_API_URL=http://127.0.0.1:18789/api
OPENCLAW_BRIDGE_PORT=8401

# --- System Settings ---
LOG_LEVEL=INFO
APPROVAL_REQUIRED=true
POLLING_INTERVAL_SECONDS=300

# ============================================================
# Code Sandbox (tools/docker_sandbox.py)
# ============================================================
# How CodeExecutorAgent runs Python. "docker" = hardened, network-isolated,
# ephemeral container (recommended). "subprocess" = local fallback, NOT isolated.
# "auto" = use docker when the daemon is reachable, else subprocess. "off" = disable.
CODE_SANDBOX_MODE=auto
# Container image used for execution (must be present locally unless auto-pull).
SANDBOX_IMAGE=python:3.12-slim
# Pull the image automatically on first use if missing (true/false).
CODE_SANDBOX_AUTO_PULL=false
# Per-run resource bounds.
SANDBOX_TIMEOUT=30
SANDBOX_TIMEOUT_MAX=120
SANDBOX_MEMORY=256m
SANDBOX_CPUS=1
SANDBOX_PIDS_LIMIT=128
SANDBOX_TMPFS_SIZE=64m
SANDBOX_MAX_CODE_BYTES=1000000
SANDBOX_MAX_OUTPUT_BYTES=32000

# ============================================================
# Self-Observability / Telemetry (telemetry/)
# ============================================================
# In-process span tracing for requests, routing, agent turns, and tool calls.
# Fully dependency-free; degrades gracefully if backends are absent.
TELEMETRY_ENABLED=true
# Capture prompt/response/code content in spans (PII risk — off by default).
TELEMETRY_CAPTURE_CONTENT=false
# Expose GET /api/v1/observability/traces and /stats (404 when false).
OBSERVABILITY_API_ENABLED=true
# Ring-buffer size for recent spans.
TELEMETRY_MAX_SPANS=500
# Optional JSONL span sink (off by default).
TELEMETRY_JSONL_ENABLED=false
# TELEMETRY_JSONL_PATH=
# Optional external trace backends (require the commented extras in requirements.txt).
# OTEL_EXPORTER_OTLP_ENDPOINT=
# LANGFUSE_PUBLIC_KEY=<placeholder>
# LANGFUSE_SECRET_KEY=<placeholder>
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- MCP (Model Context Protocol) ---
# Microsoft Docs MCP — public, no auth required (default URL works out of the box)
MCP_DOCS_URL=https://learn.microsoft.com/api/mcp

# GitHub MCP — set GITHUB_TOKEN (or GITHUB_PAT) with `read:repo` + `read:org`
# scopes to enable repo/issue/code search via MCP. Leave blank to disable.
GITHUB_TOKEN=
# GITHUB_PAT=
MCP_GITHUB_URL=https://api.githubcopilot.com/mcp/
# auto = enable when GITHUB_TOKEN/GITHUB_PAT is set; true = force on; false = force off
MCP_GITHUB_ENABLED=auto

# --- RAG over Work_cases\Cases\ ---
# Root folder containing per-case subfolders (e.g. 2026-02-19_SR_1234567).
# Defaults to ~\OneDrive - Microsoft\Work_cases\Cases (then ~\Work_cases\Cases).
CASES_ROOT=
# Azure OpenAI embedding deployment (e.g. text-embedding-3-large, text-embedding-3-small).
# Leave blank to run RAG in FTS-only mode (still useful — full-text keyword search works).
AZURE_EMBEDDING_DEPLOYMENT=
AZURE_EMBEDDING_API_VERSION=2024-12-01-preview
# auto = enable embeddings when deployment is set; true = require; false = disable
RAG_EMBEDDINGS_ENABLED=auto

# ============================================================
# MCP — Tier 1 (HTTP, no auth, free; on by default)
# ============================================================
# DeepWiki — semantic search across GitHub repo wikis (Devin / Cognition Labs)
MCP_DEEPWIKI_URL=https://mcp.deepwiki.com/mcp
DEEPWIKI_MCP_ENABLED=auto

# Context7 — up-to-date framework/library docs (Upstash, vendor-neutral)
MCP_CONTEXT7_URL=https://mcp.context7.com/mcp
CONTEXT7_MCP_ENABLED=auto

# Hugging Face MCP — model/dataset/Space search and metadata
MCP_HUGGINGFACE_URL=https://huggingface.co/mcp
HUGGINGFACE_MCP_ENABLED=auto
# Optional: HF token unlocks higher rate limits + private repos
HUGGINGFACE_TOKEN=

# ============================================================
# MCP — Tier 2 (HTTP, opt-in via SaaS tokens)
# ============================================================
# Notion MCP — official Notion API integration token enables this
NOTION_TOKEN=
MCP_NOTION_URL=https://mcp.notion.com/mcp

# Sentry MCP — error/telemetry triage (org-scoped auth token)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
MCP_SENTRY_URL=https://mcp.sentry.dev/mcp

# Atlassian MCP (Jira + Confluence Cloud) — official Atlassian Remote MCP
ATLASSIAN_TOKEN=
MCP_ATLASSIAN_URL=https://mcp.atlassian.com/v1/sse

# ============================================================
# MCP — Tier 3 (stdio via npx/uvx, opt-in via env)
# Requires Node.js (npx) for filesystem/sequential-thinking/memory-graph,
# and uv (uvx) for git/sqlite/time/fetch.
# ============================================================
# Filesystem — sandboxed read/write under MCP_FILESYSTEM_ROOTS (semicolon-separated paths)
MCP_FILESYSTEM_ENABLED=false
MCP_FILESYSTEM_ROOTS=

# Sequential Thinking — structured chain-of-thought scaffolding
MCP_SEQUENTIAL_THINKING_ENABLED=auto

# Memory Graph — persistent knowledge-graph memory (default file under memory/)
MCP_MEMORY_GRAPH_ENABLED=false
MCP_MEMORY_GRAPH_PATH=

# Git — read-only git repo introspection (uses uvx mcp-server-git)
MCP_GIT_ENABLED=false

# SQLite — read-only SQLite introspection (point at any .db file)
MCP_SQLITE_ENABLED=false
MCP_SQLITE_DB=

# Time — timezone conversions and current time
MCP_TIME_ENABLED=auto

# Fetch — generic URL fetcher with HTML→Markdown normalization
MCP_FETCH_ENABLED=auto

# ============================================================
# Human-in-the-Loop Approvals (PR4) — guardrails/approval.py
# auto        = no human gate (default; non-interactive safe)
# interactive = blocking TTY prompt (local CLI only)
# durable     = persist to SQLite (memory/approvals.db) + REST decide
#               via /api/v1/approvals; survives restarts
# ============================================================
APPROVAL_MODE=auto
APPROVAL_WAIT_TIMEOUT=300
APPROVAL_POLL_INTERVAL=2

# ============================================================
# Optional: Azure AI Search vector backend (PR4) — tools/azure_search.py
# Microsoft/Azure-native vector memory. Leave blank to use the local
# SQLite FTS5 + embedding index unchanged. Requires the optional
# azure-search-documents package (see requirements.txt).
# ============================================================
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=agentsystem-cases
